
<section id="request" class="py-20">
  <div class="max-w-md mx-auto">
    <h2 class="text-3xl font-bold text-center mb-6">Request a Service</h2>
    <form class="space-y-4 bg-white dark:bg-slate-900 p-6 rounded-xl shadow">
      <input class="w-full p-3 border rounded" placeholder="Full Name" required />
      <input class="w-full p-3 border rounded" placeholder="Email" required />
      <input class="w-full p-3 border rounded" placeholder="Phone" />
      <select class="w-full p-3 border rounded">
        <option>Select Service</option>
        <option>Software Installation</option>
        <option>CCTV Installation</option>
        <option>Wall Mounting</option>
        <option>Network Setup</option>
      </select>
      <textarea class="w-full p-3 border rounded" placeholder="Additional Details"></textarea>
      <button class="w-full bg-blue-600 text-white py-3 rounded hover:bg-blue-700 transition">Submit</button>
    </form>
  </div>
</section>
