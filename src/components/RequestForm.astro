
<section id="request" class="py-20 bg-gray-50 dark:bg-slate-900">
  <div class="max-w-md mx-auto">
    <h2 class="text-3xl font-bold text-center mb-6">Request a Service</h2>
    <form action="#" method="post" class="space-y-4 bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-lg">
      <div>
        <label class="block text-sm font-medium text-gray-700">Full Name</label>
        <input name="name" class="mt-1 w-full p-3 border rounded-lg focus:ring-primary focus:border-primary" placeholder="Full Name" required />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Email</label>
        <input name="email" type="email" class="mt-1 w-full p-3 border rounded-lg focus:ring-primary focus:border-primary" placeholder="Email" required />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Phone</label>
        <input name="phone" class="mt-1 w-full p-3 border rounded-lg focus:ring-primary focus:border-primary" placeholder="Phone" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Number of Staff</label>
        <input name="staff" type="number" class="mt-1 w-full p-3 border rounded-lg focus:ring-primary focus:border-primary" placeholder="Number of Staff" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Reason for Contact</label>
        <select name="reason" class="mt-1 w-full p-3 border rounded-lg focus:ring-primary focus:border-primary">
          <option value="">Select Reason</option>
          <option>General Inquiry</option>
          <option>Technical Support</option>
          <option>Service Quote</option>
          <option>Emergency Assistance</option>
          <option>Consultation</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Location</label>
        <input name="location" class="mt-1 w-full p-3 border rounded-lg focus:ring-primary focus:border-primary" placeholder="Location" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Service</label>
        <select name="service" class="mt-1 w-full p-3 border rounded-lg focus:ring-primary focus:border-primary">
          <option value="">Select Service</option>
          <option>Managed IT Services</option>
          <option>Remote & Onsite IT Support</option>
          <option>Microsoft 365 / Google Workspace Support</option>
          <option>Cybersecurity Services</option>
          <option>Cloud Services & Migration</option>
          <option>Network Setup & Management</option>
          <option>Backup & Disaster Recovery</option>
          <option>Server Support & Virtualization</option>
          <option>Hardware Supply & Setup</option>
          <option>CCTV & Security System Installation</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Additional Information</label>
        <textarea name="information" class="mt-1 w-full p-3 border rounded-lg focus:ring-primary focus:border-primary" placeholder="Additional Information"></textarea>
      </div>
      <button type="submit" class="w-full bg-primary text-white py-3 rounded-lg hover:bg-primary-dark transition">Submit Request</button>
    </form>
  </div>
</section>
