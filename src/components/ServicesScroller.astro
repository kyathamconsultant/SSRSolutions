---
const services = [
  {
    id: 'software-installation',
    title: 'Software Installation & Configuration',
    subtitle: 'OS, business apps, and security tools installed and configured',
    bullets: ['OS setup & image deployment', 'Application install and licensing', 'Security & antivirus configuration'],
    image: '/images/service-software.jpg',
    bg: '/images/services-bg.jpg'
  },
  {
    id: 'troubleshooting',
    title: 'Troubleshooting & Technical Support',
    subtitle: 'Fast remote or onsite diagnosis and fixes',
    bullets: ['Remote desktop support', 'Hardware diagnostics', 'Performance tuning'],
    image: '/images/service-troubleshooting.jpg',
    bg: '/images/services-bg.jpg'
  },
  {
    id: 'patches-updates',
    title: 'Service Patches & System Updates',
    subtitle: 'Keep systems secure and up-to-date',
    bullets: ['Security patching', 'OS updates', 'Change control & testing'],
    image: '/images/service-updates.jpg',
    bg: '/images/services-bg.jpg'
  },
  {
    id: 'system-maintenance',
    title: 'System Maintenance & Optimization',
    subtitle: 'Backups, monitoring and health checks',
    bullets: ['Scheduled maintenance', 'Backup validation', 'Resource optimization'],
    image: '/images/service-maintenance.jpg',
    bg: '/images/services-bg.jpg'
  },
  {
    id: 'network-setup',
    title: 'Network Setup & Configuration',
    subtitle: 'Secure and performant network design',
    bullets: ['WiFi & router configuration', 'VLANs & QoS', 'Remote access & VPNs'],
    image: '/images/service-network.jpg',
    bg: '/images/services-bg.jpg'
  },
  {
    id: 'cctv-hardware',
    title: 'CCTV Installation & Hardware Support',
    subtitle: 'Cameras, recording and monitoring systems',
    bullets: ['Camera install & positioning', 'NVR / cloud configuration', 'Monitoring & alerts'],
    image: '/images/service-cctv.jpg',
    bg: '/images/services-bg.jpg'
  }
];
---

<div class="relative">
  <!-- right-side quick nav -->
  <nav class="hidden md:flex flex-col gap-3 fixed right-6 top-1/2 transform -translate-y-1/2 z-40">
    {services.map((s, i) => (
      <a href={`#${s.id}`} class="w-3 h-3 rounded-full bg-gray-300 dark:bg-gray-600 hover:bg-primary transition" aria-label={s.title} />
    ))}
  </nav>

  <div class="flex flex-col">
    {services.map((s) => (
      <section id={s.id} class="min-h-screen snap-start flex items-center" style={`background-image:url('${s.bg}'); background-size:cover; background-position:center;`}>
        <div class="absolute inset-0 bg-white/80 dark:bg-black/40"></div>
        <div class="relative z-10 max-w-5xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-8 items-center">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold mb-2">{s.title}</h2>
            <p class="text-gray-700 dark:text-gray-200 mb-4">{s.subtitle}</p>
            <ul class="list-disc list-inside text-gray-700 dark:text-gray-200 space-y-1">
              {s.bullets.map(b => <li>{b}</li>)}
            </ul>
            <div class="mt-6">
              <a href="#request" class="inline-block bg-primary text-white px-5 py-3 rounded-lg hover:bg-primary-dark transition">Request this service</a>
            </div>
          </div>
        <div class="hidden md:block">
            <img src={s.image} alt={s.title} class="h-80 w-full object-cover rounded-lg shadow-lg" />
          </div>
        </div>
      </section>
    ))}
  </div>
</div>
