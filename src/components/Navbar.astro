
<header class="fixed top-0 w-full backdrop-blur bg-white/70 dark:bg-slate-800/70 border-b z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="flex items-center gap-3">
      <img src="/logo.png" alt="SSR IT Services and Solutions" class="h-12" />
      <span class="font-semibold text-2xl md:text-3xl text-slate-800 dark:text-white">SSR IT Services and Solutions</span>
    </a>

    <nav class="hidden md:flex gap-8 text-slate-800 dark:text-white font-medium">
      <a href="/#about" class="hover:text-primary transition">About</a>
      <a href="/services" class="hover:text-primary transition">Services</a>
      <a href="/#request" class="hover:text-primary transition">Request Service</a>
      <a href="/#contact" class="hover:text-primary transition">Contact</a>
    </nav>

    <button id="nav-toggle" class="md:hidden text-slate-800 dark:text-white focus:outline-none" aria-label="Open menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-white/95 dark:bg-slate-900/95 border-t">
    <div class="flex flex-col p-4 gap-4 text-slate-800 dark:text-white">
      <a href="/#about" onclick="document.getElementById('mobile-menu').classList.add('hidden')">About</a>
      <a href="/services" onclick="document.getElementById('mobile-menu').classList.add('hidden')">Services</a>
      <a href="/#request" onclick="document.getElementById('mobile-menu').classList.add('hidden')">Request Service</a>
      <a href="/#contact" onclick="document.getElementById('mobile-menu').classList.add('hidden')">Contact</a>
    </div>
  </div>

  <script>
    (function(){
      const toggle = document.getElementById('nav-toggle');
      const menu = document.getElementById('mobile-menu');
      if(!toggle || !menu) return;
      toggle.addEventListener('click', ()=> menu.classList.toggle('hidden'));
    })();
  </script>
</header>
